# Copy this file to .env.local (dev) or set these as env vars on the server (prod).
# Never commit .env.local — it's git-ignored.

# GEMINI_API_KEY (required, SERVER-SIDE ONLY)
# The backend holds this — the frontend never sees it.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Optional: override the Gemini model. Defaults to gemini-3.1-pro-preview.
# GEMINI_MODEL="gemini-2.5-pro"

# Optional: APP_ACCESS_TOKEN — shared secret that gates the /api/* endpoints.
# When set, visitors must enter this token in the lockscreen before using the app.
# Leave unset/empty to disable the lock (useful for local dev).
# Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# APP_ACCESS_TOKEN=""

# Optional: HTTP port the Express server listens on. Defaults to 8080.
# PORT=8080

# Optional (dev only): where the Vite dev server should proxy /api requests.
# Defaults to http://localhost:8080.
# BACKEND_URL="http://localhost:8080"
